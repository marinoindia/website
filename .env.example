# Razorpay public Key ID — safe to expose in the browser (this is by design).
# Get it from Razorpay Dashboard → Settings → API Keys.
# Use rzp_test_xxx while testing, rzp_live_xxx when going live.
# Copy this file to ".env" and fill in your key, then restart the dev server.
#
# If this is left empty/unset, the webshop checkout gracefully falls back to
# sending the order via WhatsApp (no online payment).
VITE_RAZORPAY_KEY_ID=
